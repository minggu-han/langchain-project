# ==================== 环境变量配置模板 ====================
# 复制此文件为 .env 并填入实际值

# ==================== 应用配置 ====================
APP_NAME=LangChain学习项目
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# ==================== 数据库配置 ====================
# PostgreSQL + asyncpg 异步驱动
DATABASE_URL=postgresql+asyncpg://snowhan:Msi60067710@localhost:5432/security-db
# 同步版本（用于 Alembic 迁移）
DATABASE_URL_SYNC=postgresql://snowhan:Msi60067710@localhost:5432/security-db

# ==================== Redis 配置 ====================
REDIS_URL=redis://:YourStrongRedisPassword123@localhost:6379/0
REDIS_PASSWORD=YourStrongRedisPassword123

# ==================== JWT 认证配置 ====================
# 访问令牌过期时间（分钟），默认 30 分钟
ACCESS_TOKEN_EXPIRE_MINUTES=30
# 刷新令牌过期时间（天），默认 7 天
REFRESH_TOKEN_EXPIRE_DAYS=7
# JWT 加密算法
JWT_ALGORITHM=HS256

# ==================== OpenAI 配置 ====================
# LangChain 调用 LLM 所需的 API Key
# 获取地址：https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
# OpenAI 模型选择（可选：gpt-4o, gpt-4o-mini, gpt-3.5-turbo）
OPENAI_MODEL=gpt-4o-mini
# OpenAI API 基础 URL（如需使用代理或兼容 API）
# OPENAI_BASE_URL=https://api.openai.com/v1

# ==================== Milvus 向量数据库 ====================
# Milvus standalone 模式连接（通过 Docker 运行）
# docker-compose 暴露的端口：19530（gRPC）、9091（健康检查）
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_URI=http://localhost:19530
